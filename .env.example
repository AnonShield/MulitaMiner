# Exemplo de arquivo de variáveis de ambiente para MulitaMiner
# Copie este arquivo para .env e configure suas chaves de API

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (para Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Outras configurações opcionais
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=your-langsmith-key

# Configurações de timeout (opcional)
# LLM_TIMEOUT=60
# PDF_PROCESSING_TIMEOUT=300