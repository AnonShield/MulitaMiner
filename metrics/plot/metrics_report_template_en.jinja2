    rebuildDet();
  }else if(HAS_ERROR_BREAKDOWN){
    document.getElementById('tab-errors').classList.add('active');
    Array.from(document.querySelectorAll('.tab')).find(b=>b.textContent.includes('Error'))?.classList.add('active');
    built['errors']=true;
    rebuildErrorBreakdown();
  }
});
</script>
</body>
</html>
