function rebuildRadar(){
  const radarBaselineEl = document.getElementById('radarBaseline');
  if(!radarBaselineEl) return; // radarBaseline select not present
  const sel=radarBaselineEl.value;
  const bls=sel==='all'?BASELINES:[sel];
  const axes=['BERTScore','ROUGE-L','F1 Avg (IE)','Recall','Precision','Consistency'];
  mkChart('radarChart',{
    type:'radar',
    data:{
      labels:axes,
      datasets:MODELS.map(m=>{
        const c=MC[m];
        // Skip baselines/fields where the model has no data instead of using
        // synthetic defaults — keeps the average truthful when a model
        // didn't run (or failed) on a given baseline.
        const isNum=v=>typeof v==='number'&&!isNaN(v);
        const baVals=bls.map(bl=>mBert(bl,m)).filter(isNum);
        const raVals=bls.map(bl=>mRouge(bl,m)).filter(isNum);
        const f1Vals=bls.flatMap(bl=>DET_FIELDS.map(f=>det[bl]?.[m]?.[f]?.f1?.m)).filter(isNum);
        // Recall    = matched / baseline_total (coverage)
        // Precision = matched / extracted_total (purity), reused from matched_rate
        const recallVals=bls.map(bl=>recall[bl]?.[m]?.m).filter(isNum);
        const precisionVals=bls.map(bl=>matched_rate[bl]?.[m]?.m).filter(isNum);
        const ba=baVals.length?avg(baVals):0;
        const ra=raVals.length?avg(raVals):0;
        const f1Avg=f1Vals.length?avg(f1Vals):0;
        // recall and matched_rate are stored as percent (0–100); the radar uses
        // 0–1 for every other axis, so we normalize here before plotting.
        const rec=recallVals.length?avg(recallVals)/100:0;
        const prec=precisionVals.length?avg(precisionVals)/100:0;
        // Consistency: 1 - weighted avg std (0.7 IE + 0.3 NLG), same formula as consistencyChart
        const bertStds=bls.map(bl=>sBert(bl,m)).filter(isNum);
        const rougeStds=bls.map(bl=>sRouge(bl,m)).filter(isNum);
        const detStds=bls.flatMap(bl=>DET_FIELDS.map(f=>det[bl]?.[m]?.[f]?.f1?.s)).filter(isNum);
        const nlgStd=(bertStds.length?avg(bertStds):0)*0.7+(rougeStds.length?avg(rougeStds):0)*0.3;
        const ieStd=detStds.length?avg(detStds):0;
        const consistency=Math.max(0,Math.min(1,1-(0.7*ieStd+0.3*nlgStd)));
        return{label:MODEL_NAMES[m]||m,data:[ba,ra,f1Avg,rec,prec,consistency],borderColor:c,backgroundColor:c+'15',pointBackgroundColor:c,borderWidth:1.5,pointRadius:3};
      })
    },
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:LEG,tooltip:{callbacks:{label:i=>`${i.dataset.label}: ${(i.parsed.r*100).toFixed(1)}%`}}},scales:{r:{min:0,max:1.0,ticks:{color:TICKS,font:{family:'Space Mono',size:11},backdropColor:'transparent',stepSize:0.2},grid:{color:GRID},pointLabels:{color:'#94a3b8',font:{family:'Inter',size:12}}}}}
  });

  mkChart('radarGrouped',{
    type:'bar',
    data:{
      labels:MODELS.map(m=>MODEL_NAMES[m]||m),
      datasets:[
        {
          label:'BERT',
          data:MODELS.map(m=>avg(bls.map(bl=>mBert(bl,m)))),
          errorBars:MODELS.map(m=>avg(bls.map(bl=>sBert(bl,m)))),
          backgroundColor:'rgba(6,182,212,0.55)', // Cyan com transparência
          borderColor:'#0891b2',
          borderWidth:2
        },
        {
          label:'ROUGE-L',
          data:MODELS.map(m=>avg(bls.map(bl=>mRouge(bl,m)))),
          errorBars:MODELS.map(m=>avg(bls.map(bl=>sRouge(bl,m)))),
          backgroundColor:'rgba(139,92,246,0.55)', // Roxo com transparência
          borderColor:'#7c3aed',
          borderWidth:2
        },
        {
          label:'F1-Det',
          data:MODELS.map(m=>avg(bls.flatMap(bl=>DET_FIELDS.map(f=>det[bl]?.[m]?.[f]?.f1?.m??0.5)))),
          errorBars:MODELS.map(m=>avg(bls.flatMap(bl=>DET_FIELDS.map(f=>det[bl]?.[m]?.[f]?.f1?.s??0.05)))),
          backgroundColor:'rgba(236,72,153,0.55)', // Rosa com transparência
          borderColor:'#be184d',
          borderWidth:2
        },
      ]
    },
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:LEG,tooltip:{callbacks:{label:ttStd}}},scales:scaleY(0.6,1.0)}
  });
}

