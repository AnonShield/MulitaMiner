function getScoreColor(score){
  // Returns background color based on score: red (low) → yellow → green (high)
  if(score>=0.85) return '#10b981'; // green
  if(score>=0.75) return '#84cc16'; // lime
  if(score>=0.65) return '#f59e0b'; // amber
  if(score>=0.55) return '#ef4444'; // red
  return '#7f1d1d'; // dark red
}

function median(arr) {
  const sorted = [...arr].sort((a, b) => a - b);
  const mid = Math.floor(sorted.length / 2);
  return sorted.length % 2 !== 0 ? sorted[mid] : (sorted[mid - 1] + sorted[mid]) / 2;
}

function rebuildTradeoff(){
  const ieScores = MODELS.map(m => calcIEScoreAvg(m));
  const nlgScores = MODELS.map(m => calcNLGScoreAvg(m));
  const finalScores = MODELS.map(m => calcFinalScoreAvg(m));
  
  // Dynamic thresholds based on median (robust against outliers)
  const ieThreshold = median(ieScores);
  const tqThreshold = median(nlgScores);
  
  // Create ONE dataset per model to ensure Chart.js respects individual colors
  const datasets = MODELS.map((m, idx) => {
    const ie = ieScores[idx];
    const tq = nlgScores[idx];
    const fs = finalScores[idx];
    
    const ieHigh = ie >= ieThreshold;
    const tqHigh = tq >= tqThreshold;
    
    let quadrant = '';
    if(ieHigh && tqHigh) {
      quadrant = 'Balanced';
    } else if(!ieHigh && tqHigh) {
      quadrant = 'Quality-focused';
    } else if(ieHigh && !tqHigh) {
      quadrant = 'Extraction-focused';
    } else {
      quadrant = 'Needs Improvement';
    }
    
    const modelColor = MC[m] || '#e2e8f0';
    
    return {
      label: MODEL_NAMES[m] || m,
      data: [{
        x: ie,
        y: tq,
        r: 8 + (fs * 15),
        quadrant: quadrant
      }],
      backgroundColor: modelColor + 'cc',
      borderColor: modelColor,
      borderWidth: 2.5
    };
  });
  
  // Plugin to draw quadrant backgrounds
  const quadrantPlugin = {
    id: 'quadrantBackground',
    afterDatasetsDraw(chart) {
      const {ctx, chartArea: {left, top, width, height}} = chart;
      const xScale = chart.scales.x;
      const yScale = chart.scales.y;
      
      // Calculate pixel positions for dynamic median threshold lines
      const x75 = xScale.getPixelForValue(ieThreshold);
      const y75 = yScale.getPixelForValue(tqThreshold);
      
      ctx.save();
      
      // Quadrant backgrounds (very subtle)
      // Top-right: balanced (green tint)
      ctx.fillStyle = 'rgba(16,185,129,0.05)';
      ctx.fillRect(x75, top, left + width - x75, y75 - top);
      
      // Top-left: quality-focused (cyan tint)
      ctx.fillStyle = 'rgba(0,229,255,0.05)';
      ctx.fillRect(left, top, x75 - left, y75 - top);
      
      // Bottom-right: extraction-focused (amber tint)
      ctx.fillStyle = 'rgba(245,158,11,0.05)';
      ctx.fillRect(x75, y75, left + width - x75, top + height - y75);
      
      // Bottom-left: needs improve (purple tint)
      ctx.fillStyle = 'rgba(147,51,234,0.05)';
