<script>
const BASELINES = {{ baselines | tojson }};
const MODELS = {{ models | tojson }};
const bert = {{ bert_data | tojson }};
const rouge = {{ rouge_data | tojson }};
const det = {{ det_data | tojson }};
const stacked = {{ stacked_data | tojson }};
const matched_rate = {{ matched_rate | tojson }};
const recall = {{ recall | tojson }};
const absent_nonexist = {{ absent_nonexist | tojson }};
const vuln_counts = {{ vulnerability_counts | tojson }};
const error_breakdown = {{ error_breakdown | tojson }};
const fdr_fnr = {{ fdr_fnr | tojson }};
const BASELINE_SHAPES_CJS = ['triangle', 'rectRot', 'cross', 'rect', 'star', 'crossRot'];
const HAS_FDR_FNR = {{ 'true' if has_fdr_fnr else 'false' }};
const HAS_BERT = {{ 'true' if has_bert else 'false' }};
const HAS_ROUGE = {{ 'true' if has_rouge else 'false' }};
const HAS_DET = {{ 'true' if has_det else 'false' }};
const HAS_STACKED = {{ 'true' if has_stacked else 'false' }};
const HAS_RECALL = {{ 'true' if has_recall else 'false' }};
const HAS_VULN_COUNT = {{ 'true' if has_vulncount else 'false' }};
const HAS_ERROR_BREAKDOWN = {{ 'true' if has_error_breakdown else 'false' }};

// Color palette (shared across all charts)
const COLOR_PALETTE = ['#F97316','#8B5CF6','#10B981','#3B82F6','#F59E0B','#EF4444','#06B6D4','#EC4899','#A78BFA','#34D399'];

// Initialize model colors dynamically based on actual models
const MC = {};
MODELS.forEach((m, idx) => {MC[m] = COLOR_PALETTE[idx % COLOR_PALETTE.length];});

// Helper constants
const MODEL_NAMES = {};
const BASELINE_COLORS = ['#1f7067','#00a8cc','#095b81','#cd5c5c','#f18f01','#da411b'];
const SEMANTIC_FIELDS = ['description','detection_result','detection_method','product_detection_result','impact','solution','insight','log_method','references','plugin_details','instances','source'];
const DET_FIELDS = ['severity','cvss','plugin','port','protocol'];

// Load PNG images
function loadPNGImages() {
  {% if has_matched %}
  const matchedImg = document.getElementById('matchedRateImg');
  const matchedLoading = document.getElementById('matchedRateLoading');
  if (matchedImg && matchedLoading) {
    matchedImg.src = './matched_rate_chart.png';
    matchedImg.onload = function() {
      matchedImg.style.display = 'block';
      matchedLoading.style.display = 'none';
    };
    matchedImg.onerror = function() {
      matchedLoading.textContent = 'Chart not available';
    };
  }
  {% endif %}
  
  {% if has_absent_nonexist %}
  const absentImg = document.getElementById('absentNonexistImg');
  const absentLoading = document.getElementById('absentNonexistLoading');
  if (absentImg && absentLoading) {
    absentImg.src = './absent_nonexistent_chart.png';
    absentImg.onload = function() {
      absentImg.style.display = 'block';
      absentLoading.style.display = 'none';
    };
    absentImg.onerror = function() {
      absentLoading.textContent = 'Chart not available';
    };
  }
  {% endif %}
}

// Call on page load
window.addEventListener('DOMContentLoaded', loadPNGImages);

const avg = a => a.reduce((s,v)=>s+v,0)/a.length || 0;
const mBert = (bl,m) => avg(bert[bl]?.[m]?.m ?? [0.5]);
const sBert = (bl,m) => avg(bert[bl]?.[m]?.s ?? [0.05]);
const mRouge = (bl,m) => avg(rouge[bl]?.[m]?.m ?? [0.5]);
const sRouge = (bl,m) => avg(rouge[bl]?.[m]?.s ?? [0.05]);
const mAvgBl = (m,fn) => avg(BASELINES.map(bl=>fn(bl,m)));

// Final Score Calculation
// IE_score = avg F1 of deterministic fields
// NLG_score = 0.7 * BERT + 0.3 * ROUGE
// Final_score = 0.7 * IE + 0.3 * NLG
const calcIEScore = (bl,m) => {
  if(!HAS_DET) return 0;
  const f1s = DET_FIELDS.map(f => det[bl]?.[m]?.[f]?.f1?.m ?? 0.5);
  return avg(f1s);
};

const calcNLGScore = (bl,m) => {
  const b = mBert(bl,m);
  const r = mRouge(bl,m);
  return 0.7 * b + 0.3 * r;
};

const calcFinalScore = (bl,m) => {
  const ie = calcIEScore(bl,m);
  const nlg = calcNLGScore(bl,m);
  return 0.7 * ie + 0.3 * nlg;
};

const calcIEScoreAvg = (m) => avg(BASELINES.map(bl => calcIEScore(bl,m)));
const calcNLGScoreAvg = (m) => avg(BASELINES.map(bl => calcNLGScore(bl,m)));
const calcFinalScoreAvg = (m) => avg(BASELINES.map(bl => calcFinalScore(bl,m)));

function heatColor(v, type='sem'){
  if(type==='det'){
    if(v>=0.95) return{bg:'rgba(16,185,129,0.18)',tx:'#10b981'};
    if(v>=0.90) return{bg:'rgba(0,229,255,0.22)',tx:'#00e5ff'};
    if(v>=0.85) return{bg:'rgba(245,158,11,0.16)',tx:'#f59e0b'};
    return{bg:'rgba(244,63,94,0.16)',tx:'#f43f5e'};
  }
  if(v>=0.90) return{bg:'rgba(16,185,129,0.18)',tx:'#10b981'};
  if(v>=0.80) return{bg:'rgba(0,229,255,0.22)',tx:'#00e5ff'};
  if(v>=0.70) return{bg:'rgba(245,158,11,0.16)',tx:'#f59e0b'};
  return{bg:'rgba(244,63,94,0.16)',tx:'#f43f5e'};
}

function buildLegend(id, type='sem'){
  const el=document.getElementById(id); if(!el)return;
  let items;
  if(type==='corr') {
    items = [['r > 0.85 (High)','rgba(16,185,129,0.18)','#10b981'],
             ['r 0.60-0.85 (Moderate)','rgba(245,158,11,0.16)','#f59e0b'],
             ['r < 0.60 (Divergent)','rgba(244,63,94,0.16)','#f43f5e']];
  } else if(type==='det') {
    items = [['≥0.95','rgba(16,185,129,0.18)','#10b981'],['≥0.90','rgba(0,229,255,0.22)','#00e5ff'],
             ['≥0.85','rgba(245,158,11,0.16)','#f59e0b'],['<0.85','rgba(244,63,94,0.16)','#f43f5e']];
  } else {
    items = [['≥0.90','rgba(16,185,129,0.18)','#10b981'],['≥0.80','rgba(0,229,255,0.22)','#00e5ff'],
             ['≥0.70','rgba(245,158,11,0.16)','#f59e0b'],['<0.70','rgba(244,63,94,0.16)','#f43f5e']];
  }
  el.innerHTML = items.map(([l,bg,c])=>
    `<div class="legend-item"><div class="legend-box" style="background:${bg};border:1px solid ${c}"></div>${l}</div>`
  ).join('');
}

function buildHeatmap(tableId, fields, dataObj, type='sem'){
  const table = document.getElementById(tableId);
  table.innerHTML='';
  const thead = table.createTHead();
  thead.insertRow().innerHTML = `<th>Field</th>` +
    MODELS.map(m=>`<th><span style="width:8px;height:8px;border-radius:50%;background:${MC[m]};display:inline-block;margin-right:4px"></span>${MODEL_NAMES[m]||m}</th>`).join('') + `<th>Avg</th>`;
  const tbody = table.createTBody();
  fields.forEach((f,fi)=>{
    const tr = tbody.insertRow();
    let html = `<td>${f}</td>`;
    const rowMeans=[];
    MODELS.forEach(m=>{
      const v=dataObj[m]?.means?.[fi] ?? 0.5, s=dataObj[m]?.stds?.[fi] ?? 0.05;
      rowMeans.push(v);
      const c=heatColor(v,type);
      html+=`<td style="background:${c.bg};color:${c.tx}" data-tooltip="Value: ${v.toFixed(2)} ± ${s.toFixed(2)}">${v.toFixed(2)}<span class="cell-std">±${s.toFixed(2)}</span></td>`;
    });
    const a=avg(rowMeans), ac=heatColor(a,type);
    html+=`<td style="background:${ac.bg};color:${ac.tx};font-weight:700" data-tooltip="Average: ${a.toFixed(2)}">${a.toFixed(2)}</td>`;
    tr.innerHTML=html;
  });
}

const FONT={family:'Inter',size:12}, FONT_SM={family:'Inter',size:11};
const GRID='#1F1F28', TICKS='#52526A';
const LEG={labels:{color:TICKS,font:FONT_SM}};
const ttStd=ctx=>{const ds=ctx.dataset;const s=ds.errorBars?.[ctx.dataIndex]??0;return ` ${ds.label}: ${ctx.parsed.y.toFixed(3)} ±${s.toFixed(3)}`;};
const ttVal=ctx=>{const ds=ctx.dataset;return ` ${ds.label}: ${ctx.parsed.y.toFixed(3)}`;};
function scaleY(min=0.6,max=1.0){
  return{y:{min,max,ticks:{color:TICKS,font:FONT},grid:{color:GRID}},x:{ticks:{color:TICKS,font:FONT},grid:{color:GRID}}};
}

const CHARTS={};

const errPlugin={id:'errBars',afterDatasetsDraw(chart){
  const ctx=chart.ctx, yS=chart.scales.y; if(!yS)return;
  // IMPORTANT: Visual error bars represent 20% of actual std dev for readability.
  // Tooltip shows the TRUE standard deviation values. Set to 0 to hide bars completely.
  const ERR_SCALE=0.2;
  chart.data.datasets.forEach((ds,di)=>{
    if(!ds.errorBars)return;
    const meta=chart.getDatasetMeta(di); if(!meta.visible)return;
    meta.data.forEach((bar,i)=>{
      const s=ds.errorBars[i]*ERR_SCALE; if(s==null || s<0.001)return;
      const mean=ds.data[i], x=bar.x;
      const yT=yS.getPixelForValue(mean+s), yB=yS.getPixelForValue(mean-s);
      ctx.save();
      ctx.strokeStyle=ds.errorBarColor||'rgba(255,255,255,0.5)';
      ctx.lineWidth=1.5;
      ctx.beginPath(); ctx.moveTo(x,yT); ctx.lineTo(x,yB); ctx.stroke();
      for(const [xa,ya] of [[x-4,yT],[x+4,yT],[x-4,yB],[x+4,yB]].reduce((a,v,i,ar)=>i%2?[...a,[ar[i-1],v]]:a,[])){
        ctx.beginPath(); ctx.moveTo(xa[0],xa[1]); ctx.lineTo(ya[0],ya[1]); ctx.stroke();
      }
      ctx.restore();
    });
  });
}};

function mkChart(id,cfg){
  if(CHARTS[id]){CHARTS[id].destroy();delete CHARTS[id];}
  const el=document.getElementById(id); if(!el)return;
  // Adicionar errPlugin automaticamente
  if(!cfg.plugins) cfg.plugins = [];
  if(!cfg.plugins.includes(errPlugin)) cfg.plugins.push(errPlugin);
  CHARTS[id]=new Chart(el,cfg);
  return CHARTS[id];
}
function buildOverview(){
  const sc=document.getElementById('statCards'); sc.innerHTML='';
  
  // Helpers para calcular médias entre todas as baselines
  const avgBertScore = (m) => avg(BASELINES.map(bl=>mBert(bl,m)));
  const avgBertStd = (m) => avg(BASELINES.map(bl=>sBert(bl,m)));
  const avgRougeScore = (m) => avg(BASELINES.map(bl=>mRouge(bl,m)));
  const avgRougeStd = (m) => avg(BASELINES.map(bl=>sRouge(bl,m)));
  
  // Mostrar card para BERTScore se tiver dados
  if(HAS_BERT){
    const bestBert = MODELS.reduce((a,b)=>avgBertScore(a) > avgBertScore(b) ? a : b);
    const bertVal = avgBertScore(bestBert);
    const bertStd = avgBertStd(bestBert);
    const bertColor = MC[bestBert];
    
    sc.innerHTML+=`<div class="stat-card" style="border-color:${bertColor}44">
      <div class="stat-baseline">OVERALL</div>
      <div style="font-size:0.8rem;text-align:center;"><span style="width:7px;height:7px;border-radius:50%;background:${bertColor};display:inline-block;margin-right:4px"></span>${MODEL_NAMES[bestBert]||bestBert}</div>
      <div class="stat-value" style="color:${bertColor}">${bertVal.toFixed(3)}</div>
      <div class="stat-std">±${bertStd.toFixed(3)}</div>
      <div style="font-size:0.6rem;color:var(--muted);margin-top:0.15rem">best BERTScore</div>
    </div>`;
  }
  
  // Mostrar card para ROUGE-L se tiver dados
  if(HAS_ROUGE){
    const bestRouge = MODELS.reduce((a,b)=>avgRougeScore(a) > avgRougeScore(b) ? a : b);
    const rougeVal = avgRougeScore(bestRouge);
    const rougeStd = avgRougeStd(bestRouge);
    const rougeColor = MC[bestRouge];
    
    sc.innerHTML+=`<div class="stat-card" style="border-color:${rougeColor}44">
      <div class="stat-baseline">OVERALL</div>
      <div style="font-size:0.8rem;text-align:center;"><span style="width:7px;height:7px;border-radius:50%;background:${rougeColor};display:inline-block;margin-right:4px"></span>${MODEL_NAMES[bestRouge]||bestRouge}</div>
      <div class="stat-value" style="color:${rougeColor}">${rougeVal.toFixed(3)}</div>
      <div class="stat-std">±${rougeStd.toFixed(3)}</div>
      <div style="font-size:0.6rem;color:var(--muted);margin-top:0.15rem">best ROUGE-L</div>
    </div>`;
  }

  // Mostrar card para Final Score se tiver dados de IE e NLG
  if(HAS_DET || (HAS_BERT && HAS_ROUGE)){
    const bestFinal = MODELS.reduce((a,b)=>calcFinalScoreAvg(a) > calcFinalScoreAvg(b) ? a : b);
    const finalVal = calcFinalScoreAvg(bestFinal);
    const ieVal = calcIEScoreAvg(bestFinal);
    const nlgVal = calcNLGScoreAvg(bestFinal);
    const finalColor = MC[bestFinal];
    
    sc.innerHTML+=`<div class="stat-card" style="border-color:${finalColor}44">
      <div class="stat-baseline">OVERALL</div>
      <div style="font-size:0.8rem;text-align:center;"><span style="width:7px;height:7px;border-radius:50%;background:${finalColor};display:inline-block;margin-right:4px"></span>${MODEL_NAMES[bestFinal]||bestFinal}</div>
      <div class="stat-value" style="color:${finalColor}">${finalVal.toFixed(3)}</div>
      <div style="font-size:0.6rem;color:var(--muted);margin-top:0.2rem">best Final Score</div>
      <div style="font-size:0.55rem;color:var(--muted2);margin-top:0.15rem;border-top:1px solid var(--border);padding-top:0.2rem">IE: ${ieVal.toFixed(3)} • Text Quality: ${nlgVal.toFixed(3)}</div>
    </div>`;
  }
  
  // Mostrar card para contagens de vulnerabilidades se tiver dados
  if(HAS_VULN_COUNT && Object.keys(vuln_counts).length > 0){
    const firstBl = BASELINES[0];
    if(vuln_counts[firstBl]){
      const firstModel = MODELS[0];
      const counts = vuln_counts[firstBl][firstModel];
      if(counts){
        const baselineTotal = counts.baseline_total || 0;
        
        // Calculate F1-Score for each model and find best
        const f1Scores = MODELS.map(m => {
          const c = vuln_counts[firstBl][m];
          if(!c) return { model: m, f1: 0, extracted_mean: 0, matched_mean: 0, precision: 0, recall: 0 };
          const f1 = c.f1_score || 0;
          return { 
            model: m, 
            f1: f1, 
            extracted_mean: c.extracted_mean || 0,
            matched_mean: c.matched_mean || 0,
            precision: c.precision || 0, 
            recall: c.recall || 0 
          };
        });
        
        const bestModel = f1Scores.reduce((best, curr) => curr.f1 > best.f1 ? curr : best);
        const bestModelName = MODEL_NAMES[bestModel.model] || bestModel.model;
        const vulnColor = MC[bestModel.model];
        
        sc.innerHTML+=`<div class="stat-card" style="border-color:${vulnColor}44">
          <div class="stat-baseline">EXTRACTION QUALITY</div>
          <div style="font-size:0.8rem;text-align:center;"><span style="width:7px;height:7px;border-radius:50%;background:${vulnColor};display:inline-block;margin-right:4px"></span>${bestModelName}</div>
          <div class="stat-value" style="color:${vulnColor}">${bestModel.f1.toFixed(3)}</div>
          <div class="stat-std">F1-Score</div>
          <div style="font-size:0.6rem;color:var(--muted);margin-top:0.2rem">Baseline ${firstBl}: ${baselineTotal} vulns</div>
          <div style="font-size:0.55rem;color:var(--muted2);margin-top:0.15rem;border-top:1px solid var(--border);padding-top:0.2rem">
            Extracted: ${bestModel.extracted_mean.toFixed(1)} | Matched: ${bestModel.matched_mean.toFixed(1)} | Precision: ${(bestModel.precision*100).toFixed(0)}% | Recall: ${(bestModel.recall*100).toFixed(0)}%
          </div>
        </div>`;
      }
    }
  }

  // Consistency: Calculate average Final Score and estimate std from component variations
  if(HAS_BERT){
    const consistencyData = MODELS.map(m => {
      const avgScore = calcFinalScoreAvg(m);
      
      // Estimate variability from component standard deviations
      const bertStds = BASELINES.map(bl => sBert(bl, m));
      const rougeStds = BASELINES.map(bl => sRouge(bl, m));
      
      // For deterministic fields, average std across fields and baselines
      let detStd = 0;
      if(HAS_DET){
        const allDetStds = [];
        BASELINES.forEach(bl => {
          DET_FIELDS.forEach(f => {
            const fStd = det[bl]?.[m]?.[f]?.f1?.s ?? 0.02;
            allDetStds.push(fStd);
          });
        });
        detStd = allDetStds.length > 0 ? avg(allDetStds) : 0;
      }
      
      // Weighted variation: 0.7 * IE + 0.3 * NLG
      const nlgStd = (avg(bertStds) * 0.7 + avg(rougeStds) * 0.3);
      const estimatedStd = (0.7 * detStd + 0.3 * nlgStd);
      
      return { avg: avgScore, std: estimatedStd };
    });
    
    mkChart('consistencyChart', {
      type: 'bar',
      data: {
        labels: MODELS.map(m => MODEL_NAMES[m] || m),
        datasets: [{
          label: 'Final Score',
          data: consistencyData.map(d => d.avg),
          errorBars: consistencyData.map(d => d.std),
          backgroundColor: MODELS.map(m => MC[m] + '77'),
          borderColor: MODELS.map(m => MC[m]),
          borderWidth: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ttStd
            }
          }
        },
        scales: scaleY(0, 1.0)
      }
    });
  }

  const table=document.getElementById('rankTable');
  table.innerHTML='';
  const thead=table.createTHead();
  thead.insertRow().innerHTML=`<th>Model</th>`+BASELINES.map(b=>`<th>${b}</th>`).join('')+`<th>Final Score</th>`;
  const tbody=table.createTBody();
  
  // Ordenar modelos pelo Final Score
  const sortedModels = [...MODELS].sort((a,b)=>calcFinalScoreAvg(b) - calcFinalScoreAvg(a));
  
  sortedModels.forEach((m,ri)=>{
    const tr=tbody.insertRow();
    const cls=ri===0?'rank-1':ri===1?'rank-2':ri===2?'rank-3':'';
    const med=ri===0?'🥇 ':ri===1?'🥈 ':ri===2?'🥉 ':'';
    let html=`<td class="${cls}"><span style="width:7px;height:7px;border-radius:50%;background:${MC[m]};display:inline-block;margin-right:5px"></span>${med}${MODEL_NAMES[m]||m}</td>`;
    BASELINES.forEach(bl=>{
      const v=mBert(bl,m),s=sBert(bl,m);
      html+=`<td>${v.toFixed(3)} <span class="std-inline">±${s.toFixed(3)}</span></td>`;
    });
    html+=`<td class="${cls}" style="font-weight:700">${calcFinalScoreAvg(m).toFixed(3)}</td>`;
    tr.innerHTML=html;
  });

  // Build variability table
  buildVariabilityTable();
}

function buildVariabilityTable(){
  const tbody = document.getElementById('variabilityTable');
  if(!tbody) return;
  
  tbody.innerHTML = '';
  
  MODELS.forEach(m => {
    const bertStds = BASELINES.map(bl => sBert(bl, m));
    const rougeStds = BASELINES.map(bl => sRouge(bl, m));
    
    // Calculate average std from all metric stds
    let allStds = [...bertStds, ...rougeStds];
    
    // Add deterministic stds if available
    if(HAS_DET){
      BASELINES.forEach(bl => {
        DET_FIELDS.forEach(f => {
          const fStd = det[bl]?.[m]?.[f]?.f1?.s ?? 0.02;
          allStds.push(fStd);
        });
      });
    }
    
    const avgStd = allStds.length > 0 ? avg(allStds) : 0;
    
    // Determine consistency level and color
    let level = '';
    let color = '';
    let interpretation = '';
    let confidence = '';
    
    if(avgStd < 0.05){
      level = 'Very Stable';
      color = '#10b981';
      interpretation = 'Highly consistent across runs';
      confidence = '95%+ confidence';
    }else if(avgStd < 0.08){
      level = 'Stable';
      color = '#84cc16';
      interpretation = 'Good consistency with minor variation';
      confidence = '85-95% confidence';
    }else if(avgStd < 0.12){
      level = 'Moderate';
      color = '#f59e0b';
      interpretation = 'Noticeable variation; acceptable';
      confidence = '70-85% confidence';
    }else{
      level = 'Variable';
      color = '#ef4444';
      interpretation = 'High variation; use caution';
      confidence = '< 70% confidence';
    }
    
    const tr = tbody.insertRow();
    tr.innerHTML = `
      <td style="color:${MC[m]};font-weight:700">${MODEL_NAMES[m] || m}</td>
      <td style="text-align:center;font-family:'Space Mono',monospace;font-weight:600">${avgStd.toFixed(4)}</td>
      <td style="text-align:center;color:${color};font-weight:700">${level}</td>
      <td style="text-align:center;color:var(--muted);font-size:0.65rem">${interpretation}</td>
      <td style="text-align:center;font-weight:600;color:${color}">${confidence}</td>
    `;
  });
}

