<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MulitaMiner — Metrics Dashboard</title>
<script>
  // Load Chart.js from CDN
  window.chartReady = new Promise((resolve) => {
    var script = document.createElement('script');
    script.src = 'https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js';
    script.onload = resolve;
    document.head.appendChild(script);
  });
</script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap');

:root {
  /* Surfaces */
  --bg:       #0B0B0E;
  --surface:  #111116;
  --surface2: #18181F;
  --surface3: #1D1D26;
  --surface4: #23232E;
  /* Borders */
  --border:  #1F1F28;
  --border2: #2C2C3A;
  --border3: #3A3A4E;
  /* Primary — orange */
  --accent:  #F97316;
  --accent2: #8B5CF6;
  --accent3: #10B981;
  --accent4: #F59E0B;
  --accent5: #EF4444;
  /* Text */
  --text:   #EEEEF2;
  --text2:  #B4B4C8;
  --muted:  #52526A;
  --muted2: #8A8AA0;
  /* Typography */
  --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
  /* Radius */
  --r-xs: 4px;
  --r-sm: 6px;
  --r-md: 10px;
  --r-lg: 16px;
  /* Aliases for legacy inline styles */
  --radius-sm: var(--r-sm);
  --radius-md: var(--r-md);
  /* Shadows */
  --shadow-sm: 0 1px 3px rgba(0,0,0,.5);
  --shadow-md: 0 4px 16px rgba(0,0,0,.55), 0 1px 4px rgba(0,0,0,.3);
  /* Transition */
  --t: 140ms ease;
}

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-sans);
  font-size: 14px;
  line-height: 1.55;
  min-height: 100vh;
  padding: 32px 28px;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* ── Header ─────────────────────────────────── */
header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
  padding-bottom: 20px;
  margin-bottom: 28px;
  border-bottom: 1px solid var(--border);
}
.logo { font-size: 18px; font-weight: 600; letter-spacing: -0.03em; }
.logo span { color: var(--accent); }
.subtitle { font-size: 11px; font-family: var(--font-mono); color: var(--muted); margin-top: 3px; }

/* ── Badges ─────────────────────────────────── */
.badge-row { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
.badge {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 11px; font-weight: 500; padding: 2px 9px;
  border-radius: 20px; border: 1px solid;
}
.badge::before {
  content: ''; width: 4px; height: 4px; border-radius: 50%;
  background: currentColor; opacity: .65; flex-shrink: 0;
}
.badge-bert  { border-color: rgba(249,115,22,.4);  color: var(--accent);  background: rgba(249,115,22,.07); }
.badge-rouge { border-color: rgba(16,185,129,.4);  color: var(--accent3); background: rgba(16,185,129,.07); }
.badge-det   { border-color: rgba(245,158,11,.4);  color: var(--accent4); background: rgba(245,158,11,.07); }
.badge-std   { border-color: rgba(139,92,246,.4);  color: var(--accent2); background: rgba(139,92,246,.07); }

/* ── Tabs — segment control ─────────────────── */
.tabs {
  display: inline-flex; gap: 1px;
  background: var(--surface2); padding: 3px;
  border-radius: var(--r-md); border: 1px solid var(--border);
  margin-bottom: 24px; flex-wrap: wrap;
}
.tab {
  font-size: 13px; font-weight: 500; padding: 5px 14px;
  border-radius: 7px; border: none; background: transparent;
  color: var(--muted2); cursor: pointer;
  transition: all var(--t); white-space: nowrap; letter-spacing: -.01em;
}
.tab:hover  { color: var(--text2); background: var(--surface3); }
.tab.active { color: var(--text); background: var(--surface4); box-shadow: var(--shadow-sm); }
.panel { display: none; }
.panel.active { display: block; }

/* ── Controls ───────────────────────────────── */
.controls { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
.ctrl-label { font-size: 12px; font-weight: 500; color: var(--muted); }
select {
  background: var(--surface2); border: 1px solid var(--border2);
  border-radius: var(--r-sm); color: var(--text2);
  font-family: var(--font-sans); font-size: 12px; padding: 4px 10px;
  cursor: pointer; outline: none; -webkit-appearance: none; appearance: none;
  transition: border-color var(--t);
}
select:hover { border-color: var(--border3); }
select:focus { border-color: var(--accent); }
.btn-group { display: flex; }
.btn-toggle {
  font-size: 12px; font-weight: 500; padding: 4px 12px;
  background: var(--surface2); border: 1px solid var(--border2);
  color: var(--muted2); cursor: pointer; transition: all var(--t); white-space: nowrap;
}
.btn-toggle:first-child { border-radius: var(--r-sm) 0 0 var(--r-sm); }
.btn-toggle:last-child  { border-radius: 0 var(--r-sm) var(--r-sm) 0; }
.btn-toggle:only-child  { border-radius: var(--r-sm); }
.btn-toggle:hover:not(.on) { color: var(--text2); background: var(--surface3); }
.btn-toggle.on { background: var(--accent); color: #fff; border-color: var(--accent); }

/* Range inputs */
input[type="range"] {
  -webkit-appearance: none; appearance: none;
  height: 4px; background: var(--border3);
  border-radius: 2px; cursor: pointer; outline: none;
}
input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none; width: 14px; height: 14px;
  background: var(--accent); border-radius: 50%; cursor: pointer;
  box-shadow: 0 0 0 3px rgba(249,115,22,.2);
}
input[type="range"]::-moz-range-thumb {
  width: 14px; height: 14px; background: var(--accent);
  border-radius: 50%; cursor: pointer; border: none;
}

/* ── Grid & Cards ───────────────────────────── */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 16px; }

.card, .card-full {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 20px;
  box-shadow: var(--shadow-sm);
  transition: border-color var(--t);
}
.card { display: flex; flex-direction: column; }
.card-full { display: flex; flex-direction: column; margin-bottom: 16px; }
.card:hover, .card-full:hover { border-color: var(--border2); }

/* ── Card Title ─────────────────────────────── */
.card-title {
  font-size: 11px; font-weight: 600; color: var(--muted2);
  text-transform: uppercase; letter-spacing: .07em;
  margin-bottom: 16px;
  display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
}
.card-title::before {
  content: ''; width: 5px; height: 5px; border-radius: 50%;
  background: var(--accent); flex-shrink: 0;
}
.card-title.rouge::before   { background: var(--accent3); }
.card-title.det::before     { background: var(--accent4); }
.card-title.radar::before   { background: var(--accent2); }
.card-title.stacked::before { background: var(--accent5); }

/* ── Chart Description ──────────────────────── */
.chart-description {
  font-size: 12px; color: var(--muted2); line-height: 1.6;
  margin-bottom: 16px; padding: 10px 12px;
  background: var(--surface2);
  border-left: 2px solid var(--border3);
  border-radius: 0 var(--r-sm) var(--r-sm) 0;
}

/* ── Stat Cards ─────────────────────────────── */
.stat-card {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 16px 20px; text-align: center;
  position: relative; overflow: hidden;
  transition: all var(--t);
}
.stat-card::after {
  content: ''; position: absolute;
  top: 0; left: 15%; right: 15%; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(249,115,22,.55), transparent);
}
.stat-card:hover { border-color: var(--border2); transform: translateY(-1px); box-shadow: var(--shadow-md); }
.stat-baseline { font-size: 10px; font-weight: 600; letter-spacing: .09em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
.stat-value    { font-family: var(--font-mono); font-size: 28px; font-weight: 700; letter-spacing: -.03em; line-height: 1.1; }
.stat-std      { font-family: var(--font-mono); font-size: 11px; color: var(--muted); margin-top: 3px; }

/* ── Tables ─────────────────────────────────── */
.rank-table { width: 100%; border-collapse: collapse; }
.rank-table th {
  font-size: 11px; font-weight: 600; color: var(--muted);
  padding: 8px 12px; border-bottom: 1px solid var(--border2);
  text-align: left; letter-spacing: .05em; text-transform: uppercase;
  white-space: nowrap; background: var(--surface2);
}
.rank-table td {
  padding: 8px 12px; border-bottom: 1px solid var(--border);
  font-family: var(--font-mono); font-size: 12px; color: var(--text2); white-space: nowrap;
}
.rank-table tr:last-child td { border-bottom: none; }
.rank-table tr:hover td { background: var(--surface2); color: var(--text); }
.rank-1 { color: var(--accent4) !important; font-weight: 700; }
.rank-2 { color: var(--muted2) !important; }
.rank-3 { color: #cd7f32 !important; }
.std-inline { color: var(--muted); font-size: 10px; }

/* ── Heatmap Table ───────────────────────────── */
.heatmap-table { width: 100%; border-collapse: collapse; margin: 12px 0; }
.heatmap-table th {
  font-size: 11px; font-weight: 600; color: var(--muted);
  padding: 8px 10px; border-bottom: 1px solid var(--border2);
  text-align: center; letter-spacing: .05em; text-transform: uppercase;
  background: var(--surface2);
}
.heatmap-table th:first-child { text-align: left; }
.heatmap-table td { padding: 8px 10px; border-bottom: 1px solid var(--border); font-family: var(--font-mono); font-size: 12px; text-align: center; color: var(--text2); }
.heatmap-table td:first-child { text-align: left; font-weight: 600; color: var(--text); }
.heatmap-table tr:hover { background: var(--surface3); }
.heatmap-cell { border-radius: var(--r-xs); padding: 4px 8px; color: var(--text); font-weight: 700; }

/* ── Dynamic Heatmap ────────────────────────── */
.heatmap-wrap { overflow-x: auto; }
.heatmap { width: 100%; border-collapse: collapse; }
.heatmap th {
  font-size: 11px; font-weight: 600; color: var(--muted);
  padding: 8px 10px; text-align: center; white-space: nowrap;
  border-bottom: 1px solid var(--border2); letter-spacing: .05em;
  text-transform: uppercase; background: var(--surface2);
}
.heatmap th:first-child { text-align: left; }
.heatmap td {
  padding: 7px 10px; text-align: center;
  border-bottom: 1px solid var(--border);
  font-family: var(--font-mono); font-size: 12px;
  white-space: nowrap; position: relative; cursor: help;
  transition: background var(--t); color: var(--text2);
}
.heatmap td:first-child { text-align: left; color: var(--text); padding-left: 4px; font-weight: 500; }
.heatmap tr:hover td { background: var(--surface2); }
.heatmap td[data-tooltip]:hover::after {
  content: attr(data-tooltip);
  position: absolute; bottom: calc(100% + 6px); left: 50%; transform: translateX(-50%);
  background: var(--surface3); border: 1px solid var(--border2);
  border-radius: var(--r-sm); padding: 6px 10px; font-size: 11px;
  font-family: var(--font-sans); white-space: nowrap; color: var(--text2);
  z-index: 100; box-shadow: var(--shadow-md); pointer-events: none;
}
.heatmap td[data-tooltip]:hover::before {
  content: ''; position: absolute;
  bottom: calc(100% + 1px); left: 50%; transform: translateX(-50%);
  border: 4px solid transparent; border-top-color: var(--surface3); z-index: 101;
}
.cell-std { font-size: 10px; opacity: .5; display: block; margin-top: 1px; }

/* ── Legend ─────────────────────────────────── */
.legend { display: flex; gap: 10px; margin-top: 12px; flex-wrap: wrap; }
.legend-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--muted2); font-weight: 500; }
.legend-box { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }

/* ── Methodology ────────────────────────────── */
.methodology-card { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--r-sm); padding: 16px; margin-bottom: 16px; }
.methodology-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.methodology-title { font-size: 11px; font-weight: 600; color: var(--muted2); letter-spacing: .06em; text-transform: uppercase; }
.info-btn { background: var(--accent); color: #fff; border: none; width: 20px; height: 20px; border-radius: 50%; cursor: pointer; font-size: 11px; display: flex; align-items: center; justify-content: center; transition: all var(--t); font-weight: 700; flex-shrink: 0; }
.info-btn:hover { background: var(--accent2); transform: scale(1.1); }
.formula-box { background: var(--bg); border: 1px solid var(--border2); border-left: 2px solid var(--accent); padding: 10px 14px; border-radius: 0 var(--r-sm) var(--r-sm) 0; font-family: var(--font-mono); font-size: 13px; color: var(--text); line-height: 1.6; margin: 8px 0; }
.formula-details { display: none; padding-top: 12px; border-top: 1px solid var(--border); margin-top: 12px; }
.formula-details.show { display: block; }
.detail-item { display: flex; gap: 8px; margin: 6px 0; font-size: 12px; color: var(--muted2); }
.detail-item-bullet { color: var(--accent3); font-weight: 700; flex-shrink: 0; width: 1.2rem; }

/* ── Canvas ─────────────────────────────────── */
canvas { width: 100% !important; height: auto !important; display: block; }
canvas#consistencyChart    { height: 675px !important; }
canvas#blLineChart         { height: 500px !important; }
canvas#stackedBar          { height: 400px !important; }
canvas#semBar              { height: 500px !important; }
canvas#detPrecRec          { height: 450px !important; }
canvas#radarChart          { height: 800px !important; }
canvas#radarGrouped        { height: 800px !important; }
canvas#finalScoreChart     { height: 600px !important; }
canvas#tradeoffBubbleChart { height: 560px !important; }
canvas#fdrFnrChart         { height: 450px !important; }
canvas#matchedRateChart    { height: 500px !important; }
canvas#absentChart         { height: 500px !important; }

/* ── Footer ─────────────────────────────────── */
footer {
  margin-top: 48px; padding: 18px 0;
  border-top: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  gap: 8px; flex-wrap: wrap;
  font-size: 12px; color: var(--muted);
}
footer span + span::before { content: '·'; margin-right: 8px; color: var(--border3); }

/* ── Responsive ─────────────────────────────── */
@media (max-width: 900px) {
  .grid-2, .grid-3 { grid-template-columns: 1fr; }
  body { padding: 16px; }
  .tabs { display: flex; width: 100%; }
  .tab { flex: 1; text-align: center; font-size: 12px; }
}
</style>
</head>
<body>

<header>
  <div>
    <div class="logo">Mulita<span>Miner</span></div>
    <div class="subtitle">// Metrics Evaluation Dashboard — {{ report_date }}</div>
  </div>
  <div class="badge-row">
    {% if has_bert %}<span class="badge badge-bert">BERTScore</span>{% endif %}
    {% if has_rouge %}<span class="badge badge-rouge">ROUGE-L</span>{% endif %}
    {% if has_det %}<span class="badge badge-det">Deterministic</span>{% endif %}
    {% if has_stacked %}<span class="badge badge-std">Similarity</span>{% endif %}
  </div>
</header>

<div class="tabs">
  {% if has_bert %}
  <button class="tab active" onclick="showTab('overview',this)">Overview</button>
  <button class="tab" onclick="showTab('performance',this)">Performance Breakdown</button>
  <button class="tab" onclick="showTab('comparison',this)">Model Comparison</button>
  <button class="tab" onclick="showTab('insights',this)">Trade-off & Insights</button>
  {% endif %}
  {% if has_error_breakdown %}
  <button class="tab" onclick="showTab('errors',this)">Error Analysis</button>
  {% endif %}
</div>

<!-- ══ TAB 1: OVERVIEW ══ -->
{% if has_bert %}
<div class="panel active" id="tab-overview">
  <div class="grid-3" id="statCards"></div>
  <div class="grid-2">
    <div class="card">
      <div class="card-title">Model Consistency — Final Score Across Runs</div>
      <div class="chart-description">Shows Final Score variation across runs for each model. Error bars represent min-max range; narrower bars indicate more consistent models. Helps identify which models are deterministic versus stochastic.</div>
      <canvas id="consistencyChart" height="270"></canvas>
    </div>
    <div class="card">
      <div class="card-title">Rankings — Final Score (Weighted Composite)</div>
      <div class="chart-description">Ranked models by overall combined performance. Final Score integrates both structured extraction (IE, 70%) and text quality (70% semantic + 30% linguistic, 30%), providing a holistic evaluation metric.</div>
      <table class="rank-table" id="rankTable"></table>
    </div>
  </div>
  <div class="card-full">
    <div class="card-title">Run Variability Analysis — Consistency Context</div>
    <div class="chart-description">
      Shows consistency of each model across multiple runs. <strong>Standard Deviation (σ)</strong> measures performance variance:
      <br>• <strong style="color:#10b981">Low σ (< 0.05):</strong> Stable, reliable model — results are reproducible
      <br>• <strong style="color:#f59e0b">Medium σ (0.05-0.10):</strong> Moderate variance — acceptable but some run-to-run variation
      <br>• <strong style="color:#ef4444">High σ (> 0.10):</strong> High variance — results may be unstable; recommend more runs for confidence
    </div>
    <table class="heatmap-table" style="width:auto;margin:1rem 0">
      <thead>
        <tr>
          <th style="text-align:left;width:15%">Model</th>
          <th style="text-align:center;width:18%">Avg σ (All Metrics)</th>
          <th style="text-align:center;width:25%">Consistency Level</th>
          <th style="text-align:center;width:20%">Interpretation</th>
          <th style="text-align:center;width:22%">Confidence</th>
        </tr>
      </thead>
      <tbody id="variabilityTable"></tbody>
    </table>
  </div>
</div>
{% endif %}

<!-- ══ TAB 2: PERFORMANCE BREAKDOWN ══ -->
<div class="panel" id="tab-performance">
  <!-- ══ SECTION: TEXT QUALITY ══ -->
  {% if has_bert or has_rouge %}
  <div style="margin-bottom:32px;padding-bottom:24px;border-bottom:1px solid var(--border2);">
    <div style="font-family:var(--font-sans); font-size:11px; font-weight:600; color:var(--accent); margin-bottom:20px; letter-spacing:.08em; text-transform:uppercase; display:flex; align-items:center; gap:8px;"><span style="display:inline-block;width:3px;height:14px;border-radius:2px;background:var(--accent);"></span>Text Quality</div>
    
    {% if has_bert and has_rouge %}
    <div class="controls">
      <span class="ctrl-label">Metric:</span>
      <div class="btn-group">
        <button class="btn-toggle on" id="semBert"  onclick="setSemMetric('bert')">BERT</button>
        <button class="btn-toggle"   id="semRouge" onclick="setSemMetric('rouge')">ROUGE-L</button>
      </div>
      <span class="ctrl-label">Baseline:</span>
      <select id="semBaseline" onchange="rebuildSemantic()">
        {% for bl in baselines %}<option value="{{ bl }}">{{ bl }}</option>{% endfor %}
      </select>
    </div>
    {% else %}
    <div class="controls">
      <span class="ctrl-label">Baseline:</span>
      <select id="semBaseline" onchange="rebuildSemantic()">
        {% for bl in baselines %}<option value="{{ bl }}">{{ bl }}</option>{% endfor %}
      </select>
    </div>
    {% endif %}
    
    <div class="card-full">
      <div class="card-title" id="semHeatTitle">{% if has_bert %}BERTScore{% else %}ROUGE-L{% endif %} Heatmap — Text Quality Fields × Models</div>
      <div class="chart-description">(BERT/ROUGE-L) field-level performance heatmap. Darker cells indicate higher similarity scores. Each cell shows mean ± std for that field and model pair.</div>
      <div class="heatmap-wrap"><table class="heatmap" id="semHeatmap"></table></div>
      <div class="legend" id="semLegend"></div>
    </div>
    <div class="card-full">
      <div class="card-title" id="semBarTitle">{% if has_bert %}BERTScore{% else %}ROUGE-L{% endif %} per Field — per Model (±Std)</div>
      <div class="chart-description">(BERT/ROUGE-L) performance per Text Quality field. Compare how different models perform on each category (detection method, impact, references, etc.).</div>
      <canvas id="semBar" height="200"></canvas>
    </div>
  </div>
  {% endif %}

  <!-- ══ SECTION: STRUCTURED EXTRACTION ══ -->
  {% if has_det %}
  <div style="margin-bottom:32px;">
    <div style="font-family:var(--font-sans); font-size:11px; font-weight:600; color:var(--accent4); margin-bottom:20px; letter-spacing:.08em; text-transform:uppercase; display:flex; align-items:center; gap:8px;"><span style="display:inline-block;width:3px;height:14px;border-radius:2px;background:var(--accent4);"></span>Structured Extraction</div>
    
    <div class="controls">
      <span class="ctrl-label">Metric:</span>
      <div class="btn-group">
        <button class="btn-toggle on" id="detF1"   onclick="setDetMetric('f1')">F1</button>
        <button class="btn-toggle"   id="detPrec" onclick="setDetMetric('prec')">Precision</button>
        <button class="btn-toggle"   id="detRec"  onclick="setDetMetric('rec')">Recall</button>
      </div>
      <span class="ctrl-label">Baseline:</span>
      <select id="detBaseline" onchange="rebuildDet()">
        {% for bl in baselines %}<option value="{{ bl }}">{{ bl }}</option>{% endfor %}
      </select>
    </div>
    
    <div class="card-full">
      <div class="card-title det" id="detHeatTitle">F1-Score Heatmap — IE Fields × Models</div>
      <div class="chart-description">Structured field extraction accuracy (severity, CVSS, plugin id, port, protocol). Darker cells = higher F1-scores. Mean ± std shown per field-model pair.</div>
      <div class="heatmap-wrap"><table class="heatmap" id="detHeatmap"></table></div>
      <div class="legend" id="detLegend"></div>
    </div>
    <div class="card-full">
      <div class="card-title det">Precision vs Recall — per Model (average across fields, ±Std)</div>
      <div class="chart-description"><strong>Structured Field Extraction:</strong> Comparison of precision (accuracy of extracted items, yellow) and recall (completeness of extractions, purple) for deterministic fields (severity, CVSS, plugin, port, protocol). Higher values are better for both metrics.</div>
      <canvas id="detPrecRec" height="180"></canvas>
    </div>
  </div>
  {% endif %}
</div>

<!-- ══ TAB 3: MODEL COMPARISON ══ -->
<div class="panel" id="tab-comparison">
  <div class="controls">
    <span class="ctrl-label">Baseline:</span>
    <select id="radarBaseline" onchange="rebuildRadar()">
