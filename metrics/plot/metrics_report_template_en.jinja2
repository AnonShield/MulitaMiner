function rebuildFdrFnr() {
  if (!HAS_FDR_FNR || !fdr_fnr) return;

  // ── Threshold sliders ────────────────────────────────────────────────────
  const fnrThreshold = parseFloat((document.getElementById('fnrThreshold') || {value: '15'}).value);
  const fdrThreshold = parseFloat((document.getElementById('fdrThreshold') || {value: '15'}).value);
  const fnrLbl = document.getElementById('fnrThresholdLabel');
  const fdrLbl = document.getElementById('fdrThresholdLabel');
  if (fnrLbl) fnrLbl.textContent = fnrThreshold.toFixed(0) + '%';
  if (fdrLbl) fdrLbl.textContent = fdrThreshold.toFixed(0) + '%';

  // ── Active baseline filter ───────────────────────────────────────────────
  const activeBtn = document.querySelector('#fdrBaselineBtns .btn-toggle.on');
  const activeBl  = activeBtn ? activeBtn.dataset.bl : 'all';
  const showAll   = activeBl === 'all';
  const activeBls = showAll ? BASELINES : (BASELINES.includes(activeBl) ? [activeBl] : BASELINES);

  // ── Palette / shapes ─────────────────────────────────────────────────────
  const FDR_PALETTE   = ['#5B9BD5','#00D4AA','#9B72CF','#FF7F50','#F4C542','#E06C75'];
  const SHAPE_UNICODE = ['▲','◆','✚','■','★','✕'];

  // ── Custom HTML legend (two sections: LLMs + Baselines) ─────────────────
  const legendEl = document.getElementById('fdrFnrLegend');
  if (legendEl) {
    const rowStyle = 'display:flex;flex-wrap:wrap;align-items:center;font-family:\'Inter\',sans-serif;font-size:0.66rem;color:#94a3b8;';
    const lblStyle = 'color:#64748b;font-size:0.6rem;font-weight:500;min-width:58px;flex-shrink:0;';

    const llmItems = MODELS.map((m, i) => {
      const color = MC[m] || FDR_PALETTE[i % FDR_PALETTE.length];
      const name  = MODEL_NAMES[m] || m.toUpperCase();
      return `<span style="display:inline-flex;align-items:center;gap:5px;margin-right:14px;white-space:nowrap;">
        <svg width="11" height="11" viewBox="0 0 11 11"><circle cx="5.5" cy="5.5" r="5" fill="${color}"/></svg>
        <span>${name}</span></span>`;
    }).join('');

    const blItems = activeBls.map(bl => {
      const origIdx = BASELINES.indexOf(bl);
      const icon = SHAPE_UNICODE[origIdx >= 0 ? origIdx % SHAPE_UNICODE.length : 0];
      return `<span style="display:inline-flex;align-items:center;gap:5px;margin-right:14px;white-space:nowrap;">
        <span style="font-size:12px;line-height:1;">${icon}</span>
        <span>${bl}</span></span>`;
    }).join('');

    const meanItem = showAll
      ? `<span style="display:inline-flex;align-items:center;gap:5px;margin-right:14px;white-space:nowrap;">
          <svg width="14" height="14" viewBox="0 0 14 14"><circle cx="7" cy="7" r="5.5" fill="none" stroke="#94a3b8" stroke-width="2"/></svg>
          <span>Mean</span></span>`
      : '';

    legendEl.innerHTML =
      `<div style="${rowStyle}margin-bottom:4px;"><span style="${lblStyle}">LLMs</span>${llmItems}</div>` +
      `<div style="${rowStyle}"><span style="${lblStyle}">Baselines</span>${blItems}${meanItem}</div>`;
  }

  // ── Datasets (one per LLM) ───────────────────────────────────────────────
  const datasets = MODELS.map((m, mIdx) => {
    const color     = MC[m] || FDR_PALETTE[mIdx % FDR_PALETTE.length];
    const modelData = fdr_fnr[m] || {};
    const points = [], styles = [], radii = [], bgColors = [], borderWidths = [], tooltipLabels = [];

    activeBls.forEach(bl => {
      const blIdx = BASELINES.indexOf(bl);
      if (!modelData[bl]) return;
      points.push({ x: +(modelData[bl].FNR * 100).toFixed(1), y: +(modelData[bl].FDR * 100).toFixed(1) });
      styles.push(BASELINE_SHAPES_CJS[blIdx >= 0 ? blIdx % BASELINE_SHAPES_CJS.length : 0]);
      radii.push(7);
      bgColors.push(color + 'CC');
      borderWidths.push(2);
      tooltipLabels.push(bl);
    });

    // Mean: large hollow circle (border only, no fill)
    if (showAll && modelData['mean']) {
      points.push({ x: +(modelData['mean'].FNR * 100).toFixed(1), y: +(modelData['mean'].FDR * 100).toFixed(1) });
      styles.push('circle');
      radii.push(13);
      bgColors.push('transparent');
      borderWidths.push(2.5);
      tooltipLabels.push('Mean');
    }

    return {
      label: MODEL_NAMES[m] || m,
      data: points,
      _tooltipLabels: tooltipLabels,
      backgroundColor: bgColors,
      borderColor: color,
      borderWidth: borderWidths,
      pointStyle: styles,
      pointRadius: radii,
      pointHoverRadius: radii.map(r => r + 2),
    };
  });

  // ── Plugin: ideal zone + threshold guide lines ───────────────────────────
  const idealZonePlugin = {
    id: 'fdrIdealZone',
    beforeDraw(chart) {
      const { ctx, scales } = chart;
      if (!scales.x || !scales.y) return;
      const x0   = scales.x.getPixelForValue(0);
      const x1   = scales.x.getPixelForValue(fnrThreshold);
      const yTop = scales.y.getPixelForValue(fdrThreshold);
      const yBot = scales.y.getPixelForValue(0);
      ctx.save();
      // Green fill
      ctx.fillStyle = 'rgba(16,185,129,0.10)';
      ctx.fillRect(x0, yTop, x1 - x0, yBot - yTop);
      // Guide lines extending across the chart
      ctx.strokeStyle = 'rgba(16,185,129,0.30)';
      ctx.lineWidth = 1;
      ctx.setLineDash([3, 4]);
      ctx.beginPath(); ctx.moveTo(x1, scales.y.getPixelForValue(scales.y.max)); ctx.lineTo(x1, yBot); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(x0, yTop); ctx.lineTo(scales.x.getPixelForValue(scales.x.max), yTop); ctx.stroke();
      ctx.setLineDash([]);
      // Label
      ctx.fillStyle = 'rgba(16,185,129,0.55)';
      ctx.font = '10px Space Mono, monospace';
      ctx.fillText(`ideal zone  ≤${fnrThreshold}% FNR · ≤${fdrThreshold}% FDR`, x0 + 4, yBot - 6);
      ctx.restore();
    }
  };

  // ── Plugin: dashed lines from each baseline point → LLM mean ────────────
  const connectionLinesPlugin = {
    id: 'fdrConnectionLines',
    afterDraw(chart) {
      if (!showAll) return;                    // only meaningful when all baselines visible
      const { ctx, scales } = chart;
      if (!scales.x || !scales.y) return;
      MODELS.forEach((m, mIdx) => {
        const color     = MC[m] || FDR_PALETTE[mIdx % FDR_PALETTE.length];
        const modelData = fdr_fnr[m] || {};
        if (!modelData['mean']) return;
        const mx = scales.x.getPixelForValue(+(modelData['mean'].FNR * 100).toFixed(1));
        const my = scales.y.getPixelForValue(+(modelData['mean'].FDR * 100).toFixed(1));
        BASELINES.forEach(bl => {
          if (!modelData[bl]) return;
          const bx = scales.x.getPixelForValue(+(modelData[bl].FNR * 100).toFixed(1));
          const by = scales.y.getPixelForValue(+(modelData[bl].FDR * 100).toFixed(1));
          ctx.save();
          ctx.setLineDash([4, 4]);
          ctx.strokeStyle = color + '80';
          ctx.lineWidth = 1.2;
          ctx.beginPath(); ctx.moveTo(bx, by); ctx.lineTo(mx, my); ctx.stroke();
          ctx.restore();
        });
      });
    }
  };

  // ── Chart ────────────────────────────────────────────────────────────────
  mkChart('fdrFnrChart', {
    type: 'scatter',
    data: { datasets },
    plugins: [idealZonePlugin, connectionLinesPlugin],
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        x: {
          title: { display: true, text: 'FNR — % missed  =  FN / (FN + TP)', color: '#94a3b8', font: {size: 11} },
          min: 0,
          grid: { color: 'rgba(30,45,69,0.6)' },
          ticks: { callback: v => v + '%', color: '#64748b' },
        },
        y: {
          title: { display: true, text: 'FDR — % invented  =  FP / (FP + TP)', color: '#94a3b8', font: {size: 11} },
          min: 0,
          grid: { color: 'rgba(30,45,69,0.6)' },
          ticks: { callback: v => v + '%', color: '#64748b' },
        },
      },
      plugins: {
        legend: { display: false },            // replaced by custom HTML legend above
        tooltip: {
          callbacks: {
            title: ctx => {
              const ds = ctx[0].dataset;
              const bl = ds._tooltipLabels ? ds._tooltipLabels[ctx[0].dataIndex] : '';
              return `${ds.label} — ${bl}`;
            },
            label: ctx => [`FNR: ${ctx.parsed.x.toFixed(1)}%`, `FDR: ${ctx.parsed.y.toFixed(1)}%`],
          }
        }
      }
    }
  });
}

function rebuildSensitivity(){
  const ieWeight = parseFloat(document.getElementById('ieWeight').value);
  const nlgWeight = 100 - ieWeight;
  
  document.getElementById('ieWeightLabel').textContent = ieWeight + '%';
  document.getElementById('nlgWeightLabel').textContent = nlgWeight + '%';
  
  // Calculate scores with custom weights
  const scores = MODELS.map(m => {
    const ieScore = calcIEScoreAvg(m);
    const nlgScore = calcNLGScoreAvg(m);
    const customScore = (ieWeight / 100) * ieScore + (nlgWeight / 100) * nlgScore;
    
    return { model: m, score: customScore, ieScore, nlgScore, rank: 0 };
  });
  
  // Sort by score and add ranks
  scores.sort((a, b) => b.score - a.score);
  scores.forEach((s, i) => { s.rank = i + 1; });
  
  // Chart with ranking bars
  const sortedScores = scores.slice().sort((a, b) => b.score - a.score);
  
  mkChart('sensitivityChart', {
    type: 'bar',
    data: {
      labels: sortedScores.map(s => `${s.rank}. ${MODEL_NAMES[s.model] || s.model}`),
      datasets: [{
        label: 'Final Score',
        data: sortedScores.map(s => s.score),
        backgroundColor: sortedScores.map(s => MC[s.model] + '77'),
        borderColor: sortedScores.map(s => MC[s.model]),
        borderWidth: 2
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => `Score: ${ctx.parsed.x.toFixed(3)}`
          }
        }
      },
      scales: {
        x: { min: 0, max: 1.0, ticks: { color: TICKS }, grid: { color: GRID } },
        y: { ticks: { color: TICKS }, grid: { display: false } }
      }
    }
  });
  
  // Update ranking table
  const rankTable = document.getElementById('sensitivityRankTable');
  rankTable.innerHTML = '';
  scores.forEach(s => {
    const tr = rankTable.insertRow();
    const medalEmoji = s.rank === 1 ? '🥇' : s.rank === 2 ? '🥈' : s.rank === 3 ? '🥉' : '';
    tr.innerHTML = `
      <td style="font-weight:700;color:${MC[s.model]}">${medalEmoji} ${MODEL_NAMES[s.model] || s.model}</td>
      <td style="text-align:center;font-weight:700">#${s.rank}</td>
      <td style="text-align:center;font-weight:700">${s.score.toFixed(3)}</td>
      <td style="text-align:center">${s.ieScore.toFixed(3)}</td>
      <td style="text-align:center">${s.nlgScore.toFixed(3)}</td>
    `;
  });
}

function rebuildErrorBreakdown(){
  const baseline = document.getElementById('errorBaseline').value;
  
  if(!HAS_ERROR_BREAKDOWN || !error_breakdown[baseline]){
    document.getElementById('errorBreakdownTable').innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--muted);">No error breakdown data available</td></tr>';
    return;
  }
  
  const breakdownData = error_breakdown[baseline];
  const errorTable = document.getElementById('errorBreakdownTable');
  errorTable.innerHTML = '';
  
  breakdownData.forEach((item, idx) => {
    const tr = errorTable.insertRow();
    const failurePercent = (item.failure_rate * 100).toFixed(1);
    const bertScore = item.avg_bert_score !== null ? item.avg_bert_score.toFixed(3) : 'N/A';
    const rowColor = item.failure_rate >= 0.8 ? '#dc2626' : item.failure_rate >= 0.5 ? '#f59e0b' : '#10b981';
    
    tr.innerHTML = `
      <td style="font-weight:600;color:var(--text)">${item.vulnerability}</td>
      <td style="text-align:center;font-weight:700;color:${rowColor}">${failurePercent}%</td>
      <td style="text-align:center;color:var(--text)">${item.failed_models} / ${item.total_models}</td>
      <td style="text-align:center;color:var(--muted)">${bertScore}</td>
    `;
  });
}

const built={};

// Força recalculação de tamanho de todos os gráficos
function resizeAllCharts(){
  Object.values(CHARTS).forEach(chart => {
    if(chart){
      chart.resize();
    }
  });
}

function showTab(name,btn){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  btn.classList.add('active');
  
  // Recalcular tamanho após mostrar aba
  setTimeout(resizeAllCharts, 150);
  if(!built[name]){
    built[name]=true;
    if(name==='overview')buildOverview();
    if(name==='performance'){rebuildSemantic();rebuildDet();}
    if(name==='comparison'){rebuildRadar();rebuildFinalScore();rebuildTradeoff();}
    if(name==='insights'){rebuildTradeoff();rebuildCorrelation();rebuildSensitivity();if(HAS_FDR_FNR)rebuildFdrFnr();}
    if(name==='errors'){rebuildErrorBreakdown();}
  }
}

