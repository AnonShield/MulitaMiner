             oninput="rebuildFdrFnr()" style="width:150px;cursor:pointer;">
      <span id="fnrThresholdLabel" style="font-family:var(--font-mono);font-size:12px;font-weight:600;color:var(--accent);">15%</span>
      <span style="margin-left:1.5rem;" class="ctrl-label">FDR threshold (Y — % invented):</span>
      <input type="range" id="fdrThreshold" min="0" max="50" value="15" step="1"
             oninput="rebuildFdrFnr()" style="width:150px;cursor:pointer;">
      <span id="fdrThresholdLabel" style="font-family:var(--font-mono);font-size:12px;font-weight:600;color:var(--accent);">15%</span>
    </div>

    <div id="fdrFnrLegend" style="margin-bottom:8px;padding:8px 12px;background:var(--surface2);border-radius:var(--r-sm);border:1px solid var(--border);"></div>

    <div style="position:relative;height:450px;width:100%;">
