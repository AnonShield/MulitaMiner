function pearsonCorrelation(x, y) {
  if(x.length !== y.length || x.length < 2) return 0;
  const n = x.length;
  const mx = x.reduce((a, b) => a + b) / n;
  const my = y.reduce((a, b) => a + b) / n;
  const num = x.reduce((s, xi, i) => s + (xi - mx) * (y[i] - my), 0);
  const denom = Math.sqrt(x.reduce((s, xi) => s + Math.pow(xi - mx, 2), 0) * y.reduce((s, yi) => s + Math.pow(yi - my, 2), 0));
  return denom !== 0 ? num / denom : 0;
}

function rebuildCorrelation(){
  const bl = document.getElementById('corrBaseline').value;
  const bertData = bl === 'all' ? Object.keys(bert).reduce((acc, b) => Object.assign(acc, bert[b]), {}) : bert[bl];
  const rougeData = bl === 'all' ? Object.keys(rouge).reduce((acc, b) => Object.assign(acc, rouge[b]), {}) : rouge[bl];
  
  if(!bertData || !rougeData) return;
  
  // Collect all field scores for correlation scatter
  let points = [];
  SEMANTIC_FIELDS.forEach((field, fi) => {
    MODELS.forEach(m => {
      const b = bertData[m]?.m?.[fi] ?? null;
      const r = rougeData[m]?.m?.[fi] ?? null;
      if(b !== null && r !== null) {
        points.push({ x: b, y: r, model: m, field: field });
      }
    });
  });
  
  // Color by model
  const datasets = MODELS.map(m => {
    const modelPoints = points.filter(p => p.model === m);
    return {
      label: MODEL_NAMES[m] || m,
      data: modelPoints.map(p => ({ x: p.x, y: p.y })),
      backgroundColor: MC[m] + '88',
      borderColor: MC[m],
      borderWidth: 1.5,
      pointRadius: 4,
      pointHoverRadius: 6
    };
  });
  
  mkChart('correlationChart', {
    type: 'scatter',
    data: { datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: MODELS.length <= 8 },
        tooltip: {
          callbacks: {
            label: ctx => {
              const point = points.find(p => p.x === ctx.parsed.x && p.y === ctx.parsed.y);
              return point ? `${MODEL_NAMES[point.model] || point.model} — ${point.field}` : '';
            }
          }
        }
      },
      scales: {
        x: { title: { display: true, text: 'BERTScore', color: TICKS }, min: 0.5, max: 1, ticks: { color: TICKS }, grid: { color: GRID } },
        y: { title: { display: true, text: 'ROUGE-L', color: TICKS }, min: 0.5, max: 1, ticks: { color: TICKS }, grid: { color: GRID } }
      }
    }
  });
  
  // Build correlation heatmap by field
  const corrData = {};
  SEMANTIC_FIELDS.forEach(field => {
    const bertScores = MODELS.map(m => bertData[m]?.m?.[SEMANTIC_FIELDS.indexOf(field)] ?? 0.5);
    const rougeScores = MODELS.map(m => rougeData[m]?.m?.[SEMANTIC_FIELDS.indexOf(field)] ?? 0.5);
    corrData[field] = pearsonCorrelation(bertScores, rougeScores);
  });
  
  const table = document.getElementById('corrHeatmap');
  table.innerHTML = '';
  const thead = table.createTHead();
  thead.insertRow().innerHTML = `<th>Field</th><th>Correlation (r)</th><th>Interpretation</th>`;
  const tbody = table.createTBody();
  
  SEMANTIC_FIELDS.forEach(field => {
    const r = corrData[field];
    const tr = tbody.insertRow();
    let interp = '';
    if(r > 0.85) interp = 'High agreement';
    else if(r > 0.6) interp = 'Moderate agreement';
    else if(r > 0.3) interp = 'Weak link';
    else interp = 'Divergent metrics';
    
    let color = '';
    if(r > 0.85) color = '#10b98144';
    else if(r > 0.6) color = '#f59e0b44';
    else color = '#f43f5e44';
    
    tr.innerHTML = `
      <td>${field}</td>
      <td style="background:${color};font-weight:700">${r.toFixed(3)}</td>
      <td style="font-size:0.75rem;color:var(--muted2)">${interp}</td>
    `;
  });
  
  buildLegend('corrLegend', 'corr');
}

