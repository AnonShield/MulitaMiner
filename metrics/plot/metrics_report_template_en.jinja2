    <div style="font-family:var(--font-sans); font-size:11px; font-weight:600; color:var(--muted2); margin-bottom:16px; letter-spacing:.08em; text-transform:uppercase; display:flex; align-items:center; gap:8px;"><span style="display:inline-block;width:3px;height:14px;border-radius:2px;background:var(--accent3);"></span>Weight Sensitivity Analysis</div>
    
    <div class="controls">
      <span class="ctrl-label">IE Weight (%):</span>
