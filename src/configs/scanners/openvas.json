{
  "reader": "openvas",
  "prompt_template": "src/configs/templates/openvas_prompt.txt",
  "retry_attempts": 3,
  "delay_between_chunks": 2,
  "output_file": "vulnerabilities_default_openvas.json",
  "consolidation_field": "Name",
  "chunking": {
    "scanner_type": "openvas",
    "marker_pattern": "^\\s*NVT:",
    "has_pairs": false,
    "min_chunk_tokens": 800,
    "force_break_at_markers": true,
    "preserve_vulnerability_blocks": true,
    "max_vulnerabilities_per_chunk": 5,
    "description": "OpenVAS usa marcadores NVT: (severity ja capturado em initial_context_lines)"
  }
}
