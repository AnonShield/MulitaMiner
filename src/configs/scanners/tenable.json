{
  "reader": "tenable",
  "prompt_template": "src/configs/templates/tenable_prompt.txt",
  "retry_attempts": 3,
  "delay_between_chunks": 2,
  "output_file": "vulnerabilities_default_tenable.json",
  "consolidation_field": "Name",
  "merge_instances_with_same_base": true,
  "chunking": {
    "scanner_type": "tenable_was",
    "marker_pattern": "VULNERABILITY\\s+(CRITICAL|HIGH|MEDIUM|LOW|INFO)\\s+PLUGIN\\s+ID\\s+\\d+",
    "force_break_at_markers": true,
    "preserve_vulnerability_blocks": true,
    "max_vulnerabilities_per_chunk": 3,
    "description": "Tenable WAS usa pares BASE+INSTANCES, quebra sempre antes de marcadores VULNERABILITY"
  }
}
